# Backend origin (no trailing slash, no /api/v1). Proxy forwards `/api/v1/*` here.
# Prefer API_UPSTREAM on the server; if unset, `NEXT_PUBLIC_API_URL` is used as fallback.
API_UPSTREAM=https://viah.aidaki.ai

# Public backend base URL (same host as API_UPSTREAM). Safe to expose to the browser.
NEXT_PUBLIC_API_URL=https://viah.aidaki.ai

# App URL for server-side fetch to this Next app (must match dev server, e.g. port 3003)
# NEXT_PUBLIC_APP_URL=http://localhost:3003

# Optional UUIDs for student signup form defaults
# NEXT_PUBLIC_SIGNUP_LEVEL_ID=
# NEXT_PUBLIC_SIGNUP_SPECIALITY_ID=
